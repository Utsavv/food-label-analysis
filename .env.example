# --- Database ---
# Quick local start (SQLite):
DATABASE_URL=sqlite:///./labelwatch.db
# Production target (PostgreSQL, used automatically by docker-compose):
# DATABASE_URL=postgresql+psycopg2://labelwatch:labelwatch@localhost:5432/labelwatch

# --- Evidence / artifact storage ---
ARTIFACT_DIR=./artifacts

# --- AI provider ---
# "mock" = fully offline demo mode (default, no credentials needed)
# "google" = Gemini agents via Google ADK (requires GOOGLE_API_KEY and `pip install '.[ai]'`)
LLM_PROVIDER=mock
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- OCR provider ---
# "mock" (default) | "tesseract" (needs tesseract binary) | "google_vision" (needs GCP creds)
OCR_PROVIDER=mock
GOOGLE_APPLICATION_CREDENTIALS=

# --- Scraping etiquette ---
SCRAPER_USER_AGENT=LabelWatchIndiaBot/0.1 (+https://github.com/utsavv/food-label-analysis; food label transparency research)
SCRAPER_MIN_DELAY_SECONDS=2.0
SCRAPER_TIMEOUT_SECONDS=30.0
RESPECT_ROBOTS_TXT=true

# --- Weekly scheduler ---
ENABLE_SCHEDULER=false
WEEKLY_CHECK_DAY=mon
WEEKLY_CHECK_HOUR=6

# --- API ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
